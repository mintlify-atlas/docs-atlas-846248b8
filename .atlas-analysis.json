  "keyFeatures": [
    "Type-safe SQL query building with full TypeScript inference",
    "Support for PostgreSQL, MySQL, SQLite, and MSSQL",
    "Automatic column and table autocompletion",
    "Complex query support (joins, CTEs, subqueries, window functions)",
    "Schema creation and migrations",
    "Plugin system for extensibility",
    "Raw SQL escape hatches when needed",
    "Works in Node.js, Deno, Bun, and browsers"
  ],
  "publicApiSurface": [
    "Kysely - Main database instance class",
    "SelectQueryBuilder - SELECT query builder",
    "InsertQueryBuilder - INSERT query builder",
    "UpdateQueryBuilder - UPDATE query builder",
    "DeleteQueryBuilder - DELETE query builder",
    "MergeQueryBuilder - MERGE query builder",
    "ExpressionBuilder - Build SQL expressions",
    "RawBuilder / sql - Raw SQL template tag",
    "AggregateFunctionBuilder - Aggregate functions (sum, count, avg, etc.)",
    "CaseBuilder - CASE expressions",
    "JsonPathBuilder - JSON path operations",
    "Schema - Schema creation and modification",
    "CreateTableBuilder - CREATE TABLE builder",
    "AlterTableBuilder - ALTER TABLE builder",
    "ColumnDefinitionBuilder - Column definitions",
    "Migrator - Database migrations",
    "FileMigrationProvider - File-based migration provider",
    "PostgresDialect - PostgreSQL dialect",
    "MysqlDialect - MySQL dialect",
    "SqliteDialect - SQLite dialect",
    "MssqlDialect - MSSQL dialect",
    "CamelCasePlugin - Convert snake_case to camelCase",
    "WithSchemaPlugin - Set default schema",
    "ParseJsonResultsPlugin - Parse JSON results",
    "DeduplicateJoinsPlugin - Remove duplicate joins",
    "Generated<T> - Auto-generated column type",
    "ColumnType<SelectType, InsertType, UpdateType> - Column type helper",
    "Selectable<T> - Extract selectable type",
    "Insertable<T> - Extract insertable type",
    "Updateable<T> - Extract updateable type"
  ]
}
